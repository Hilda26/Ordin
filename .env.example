# GenLayer StudioNet (fixed for this project)
NEXT_PUBLIC_GENLAYER_CHAIN_ID=61999
NEXT_PUBLIC_GENLAYER_RPC_URL=https://studio.genlayer.com/api
NEXT_PUBLIC_GENLAYER_EXPLORER_URL=https://explorer-studio.genlayer.com

# Deployed Ordin contract (from `npm run deploy:contract` / deployment.json)
NEXT_PUBLIC_ORDIN_CONTRACT_ADDRESS=

# Supabase (auth, drafts, cache/indexing — never the source of truth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# server-only; required only for the indexer worker. NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY=
